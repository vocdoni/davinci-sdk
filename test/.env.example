# Required for integration tests
SEQUENCER_API_URL=https://sequencer-dev.davinci.vote
CENSUS_API_URL=https://census-dev.davinci.vote
RPC_URL=https://your-rpc-url
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional timeout override (milliseconds)
TIME_OUT=180000

# Optional: enables multichain integration test without overloading RPC_URL
MULTICHAIN_RPC_A=https://your-rpc-url-chain-a
MULTICHAIN_RPC_B=https://your-rpc-url-chain-b

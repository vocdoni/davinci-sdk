{
  "name": "@vocdoni/davinci-sdk",
  "version": "0.2.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "yarn clean && rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint-staged": "lint-staged",
    "test": "yarn test:unit && yarn test:integration",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration --runInBand",
    "test:contracts": "yarn test:contracts:unit && yarn test:contracts:integration",
    "test:contracts:unit": "jest --selectProjects unit --testPathPattern='test/contracts/unit' --passWithNoTests",
    "test:contracts:integration": "jest --selectProjects integration --testPathPattern='test/contracts/integration' --runInBand",
    "test:sequencer": "yarn test:sequencer:unit && yarn test:sequencer:integration",
    "test:sequencer:unit": "jest --selectProjects unit --testPathPattern='test/sequencer/unit'",
    "test:sequencer:integration": "jest --selectProjects integration --testPathPattern='test/sequencer/integration' --runInBand",
    "test:census": "yarn test:census:unit && yarn test:census:integration",
    "test:census:unit": "jest --selectProjects unit --testPathPattern='test/census/unit'",
    "test:census:integration": "jest --selectProjects integration --testPathPattern='test/census/integration' --runInBand",
    "test:core": "yarn test:core:unit && yarn test:core:integration",
    "test:core:unit": "jest --selectProjects unit --testPathPattern='test/core/unit' --passWithNoTests",
    "test:core:integration": "jest --selectProjects integration --testPathPattern='test/core/integration' --runInBand",
    "test:crypto": "yarn test:crypto:unit && yarn test:crypto:integration",
    "test:crypto:unit": "jest --selectProjects unit --testPathPattern='test/crypto/unit' --passWithNoTests",
    "test:crypto:integration": "jest --selectProjects integration --testPathPattern='test/crypto/integration' --runInBand --passWithNoTests"
  },
  "description": "A powerful TypeScript SDK for building decentralized voting applications on the Vocdoni DaVinci protocol with homomorphic encryption and zero-knowledge proofs",
  "keywords": [
    "vocdoni",
    "davinci",
    "voting",
    "blockchain",
    "ethereum",
    "decentralized",
    "privacy",
    "homomorphic-encryption",
    "zero-knowledge",
    "zk-snarks",
    "typescript",
    "sdk",
    "elections",
    "governance",
    "cryptography",
    "web3"
  ],
  "author": {
    "name": "Vocdoni",
    "email": "info@vocdoni.io",
    "url": "https://vocdoni.io"
  },
  "license": "AGPL-3.0",
  "homepage": "https://github.com/vocdoni/davinci-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vocdoni/davinci-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/vocdoni/davinci-sdk/issues"
  },
  "dependencies": {
    "@ethereumjs/common": "^4.4.0",
    "@vocdoni/davinci-contracts": "0.0.37",
    "axios": "^1.8.4",
    "buffer": "^6.0.3",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.7.1",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "lint-staged": "^15.2.0",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.5.9",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.2",
    "eslint": "^8.48.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "rimraf": "^5.0.1",
    "rollup": "^4.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "ts-jest": "^29.3.1",
    "typescript": "^5.2.2"
  }
}

# Sequencer API endpoint (e.g., https://sequencer-dev.davinci.vote)
SEQUENCER_API_URL=

# Census API endpoint (e.g., https://c3-dev.davinci.vote)
CENSUS_API_URL=

# RPC endpoint for blockchain transactions (e.g., from Infura, Alchemy, etc.)
# The chain is determined by the sequencer configuration
RPC_URL=

# Private key for transaction signing (without 0x prefix)
PRIVATE_KEY=

# (optional) CSP private key for CSP census operations (without 0x prefix)
# If not provided, a random private key will be generated
CSP_PRIVATE_KEY=

# Onchain census indexer base URL (e.g., http://localhost:8080 or https://indexer.example.org)
# onchain.ts will convert it to graphql://... when creating OnchainCensus URI.
ONCHAIN_CENSUS_INDEXER_URL=

# Existing deployed onchain census contract.
# Must satisfy ICensusValidator (WeightChanged + getCensusRoot + getRootBlockNumber + getTotalVotingPowerAtRoot).
# For this script's auto-population path, owner()/setWeight or setWeights + weightOf are also expected.
# If set, deployment params below are optional.
ONCHAIN_CENSUS_CONTRACT_ADDRESS=

# Optional start block to pass to indexer when using an existing deployed contract.
ONCHAIN_CENSUS_START_BLOCK=

# Optional contract expiration for indexer registration (RFC3339).
# If empty, onchain.ts uses now + 180 days.
ONCHAIN_CENSUS_EXPIRES_AT=

# Optional override for chain ID (defaults to RPC chain ID)
ONCHAIN_CENSUS_CHAIN_ID=

# Path to contract artifact JSON with abi+bytecode for deployment
# Optional: defaults to examples/script/artifacts/StandardOnchainCensus.json
ONCHAIN_CENSUS_ARTIFACT_PATH=

# Comma-separated private keys (with or without 0x) for already registered census members
# Optional: if empty, onchain.ts generates random wallets automatically
ONCHAIN_VOTER_PRIVATE_KEYS=

# Number of voters to auto-generate when ONCHAIN_VOTER_PRIVATE_KEYS is empty
ONCHAIN_NUM_PARTICIPANTS=5

# If true, vote choice magnitudes use onchain weights; otherwise each vote has weight 1
ONCHAIN_USE_WEIGHTS=false

# Optional max voters override for process creation (defaults to number of voter keys)
ONCHAIN_MAX_VOTERS=
